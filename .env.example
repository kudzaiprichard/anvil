# ─────────────────────────────────────────────────────────────────────────────
#  Anvil — environment template
#
#  Anvil is a FULLY OFFLINE Tauri desktop app. It ships no backend, opens no
#  network connections at runtime, and needs NO secrets, database URL, or API
#  key to build or run. `npm run tauri dev` works with none of these set.
#
#  This file exists so the few *optional* knobs — dev/build flags, the project
#  links, and the maintainer-only release tokens — are documented in one place.
#
#  Usage:  cp .env.example .env   then fill in only what you actually need.
#  `.env` is gitignored; `.env.example` is the shared, secret-free template.
# ─────────────────────────────────────────────────────────────────────────────


# ── Dev / build (Next.js + Tauri) ────────────────────────────────────────────

# Standard Next.js mode. Tooling normally sets this for you; override only if
# you have a specific reason. One of: development | production | test
NODE_ENV=development

# Host the Next.js dev server binds to when driving Tauri (mobile / LAN device
# testing). Leave unset for plain desktop dev — it defaults to "localhost".
# TAURI_DEV_HOST=localhost


# ── Project links (informational — not read by the app) ──────────────────────
# The app is not URL-configurable; these are recorded here so contributors and
# release tooling reference one canonical source. See src-tauri/tauri.conf.json.

# Source repository (this repo).
ANVIL_REPO_URL=https://github.com/kudzaiprichard/anvil

# Where built installers are published — a SEPARATE repo from the source, so the
# LeetCode-derived catalog scrape can never leak into a public release. Downloads
# and the release workflow both target this repo. See RELEASING.md.
ANVIL_RELEASES_REPO_URL=https://github.com/kudzaiprichard/anvil-releases

# Homepage advertised in the bundle metadata.
ANVIL_HOMEPAGE=https://github.com/kudzaiprichard/anvil


# ── Release tooling (MAINTAINER ONLY — leave blank otherwise) ─────────────────
# Only needed to run `node release.mjs` / `gh` locally to cut a release. In CI
# these live as GitHub Actions secrets, NOT in this file. Never commit real
# values. See .github/workflows/release.yml and RELEASING.md.

# A GitHub token for the `gh` CLI (repo read + release management).
# GH_TOKEN=
# GITHUB_TOKEN=

# Fine-grained PAT scoped to ONLY kudzaiprichard/anvil-releases with
# "Contents: write" — lets the cross-repo publish step upload installers.
# Generate at: https://github.com/settings/tokens?type=beta
# RELEASES_REPO_TOKEN=


# ── Catalog source (fetched-and-embedded at BUILD time) ──────────────────────
# ONE knob. The build fetches whatever this RAW URL points to and embeds it into
# src-tauri/resources/catalog/ — automatically, via Tauri's before-commands:
#     tauri dev   -> npm run catalog:fetch:dev  (mode=dev)
#     tauri build -> npm run catalog:fetch:prod (mode=prod)
# No more running `npm run catalog:fetch` by hand. If this variable is unset the
# build FAILS by design. The download is skipped when the file already exists;
# pass --force or set ANVIL_CATALOG_REFRESH=1 to re-download.
#
# Its VALUE is what changes per environment:
#   • Locally (dev) point it at your dev LeetCode catalog. That scrape is
#     gitignored, dev-only, and MUST NOT be committed or shipped (DISCLAIMER.md
#     §3–4). A *leetcode* file is blocked from installers by the release boundary
#     gate (tools/check_release_boundary.py).
#   • In CI / a release build (prod) set it to your OWN, shippable catalog. A
#     prod build first PURGES any *leetcode* scrape, then refuses outright if
#     this URL still resolves to a *leetcode* file — it can never be bundled.
ANVIL_CATALOG_URL=https://raw.githubusercontent.com/kudzaiprichard/catalog_leetcode/main/catalog_leetcode.json

# Force a re-download even when the catalog file is already present (default: 0).
# ANVIL_CATALOG_REFRESH=0


# ── Advanced / optional runtime overrides ────────────────────────────────────
# Normally auto-detected — set only when debugging a specific machine.

# Absolute path to the bundled Python standard library the sandboxed runner
# injects. Anvil resolves this itself at startup; override to point the runner
# at a different pylib. See src-tauri/src/lib.rs.
# ANVIL_PYLIB=

# Catalog smoke-test knobs (used by `cargo test`, not the app): number of
# problems to sample and the RNG seed for reproducibility.
# ANVIL_SMOKE_N=50
# ANVIL_SMOKE_SEED=1
