# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local project docs (kept out of version control)
/.docs/

# Question-catalog resources. The loader picks up ANY `catalog*.json[.gz]` in
# resources/ by convention, so original and scraped catalogs can coexist locally.
# Only the LeetCode scrape is dev-only and legally un-shippable (see DISCLAIMER.md)
# — it must NEVER be committed. Everything matching *leetcode* is hard-ignored;
# an original, redistributable `catalog.json[.gz]` is intended to be committed.
/src-tauri/resources/*leetcode*.json
/src-tauri/resources/*leetcode*.json.gz

# editors & IDEs
.idea/
*.iml
.vscode/
.vs/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# local UI screenshots (review artifacts)
/.shots/
/archive/

# scratch / scrape work artifacts (not part of the project)
/scratch_batch*.json
/tmp_extract/

# pack-authoring working state (ephemeral)
/tools/packs/.progress/
/tools/packs/.lock/

# python bytecode
__pycache__/
*.pyc

# tools scratch artifacts
/tools/_*
/tools/packs/.b*.txt
