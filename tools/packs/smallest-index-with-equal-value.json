    "python": "class Solution:\n    def smallestEqual(self, nums):\n        for i, v in enumerate(nums):\n            if i % 10 == v:\n                return i\n        return -1\n",
    "javascript": "var smallestEqual = function(nums) {\n    for (let i = 0; i < nums.length; i++) {\n        if (i % 10 === nums[i]) return i;\n    }\n    return -1;\n};\n"
