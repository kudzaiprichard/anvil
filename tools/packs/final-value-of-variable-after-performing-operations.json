      "description": "a random sequence of all four operation spellings at the maximum length",
      "seed": 12,
      "size": 100,
      "generator_python": "def gen(rng, size):\n    n = max(1, min(size, 100))\n    forms = ['++X', 'X++', '--X', 'X--']\n    ops = [rng.choice(forms) for _ in range(n)]\n    return [ops]\n"
    }
  ],
  "oracle_python": "class Solution:\n    def finalValueAfterOperations(self, operations):\n        x = 0\n        for op in operations:\n            if op == '++X' or op == 'X++':\n                x += 1\n            elif op == '--X' or op == 'X--':\n                x -= 1\n        return x\n",
  "solutions": {
    "python": "class Solution:\n    def finalValueAfterOperations(self, operations):\n        x = 0\n        for op in operations:\n            x += 1 if '+' in op else -1\n        return x\n",
    "javascript": "var finalValueAfterOperations = function(operations) {\n    let x = 0;\n    for (const op of operations) {\n        x += op.includes('+') ? 1 : -1;\n    }\n    return x;\n};\n"
  },
