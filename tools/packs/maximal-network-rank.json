    {
      "description": "random city count with a random subset of possible roads",
      "seed": 501,
      "size": 100,
      "generator_python": "def gen(rng, size):\n    n = rng.randint(2, min(100, max(2, size)))\n    pairs = [(i, j) for i in range(n) for j in range(i + 1, n)]\n    rng.shuffle(pairs)\n    m = rng.randint(0, len(pairs))\n    roads = [list(p) for p in pairs[:m]]\n    return [n, roads]\n"
    }
  ],
  "oracle_python": "class Solution:\n    def maximalNetworkRank(self, n: int, roads: List[List[int]]) -> int:\n        adj = [[False] * n for _ in range(n)]\n        deg = [0] * n\n        for a, b in roads:\n            if not adj[a][b]:\n                adj[a][b] = True\n                adj[b][a] = True\n                deg[a] += 1\n                deg[b] += 1\n        best = 0\n        for i in range(n):\n            for j in range(n):\n                if i == j:\n                    continue\n                rank = deg[i] + deg[j] - (1 if adj[i][j] else 0)\n                if rank > best:\n                    best = rank\n        return best\n",
  "solutions": {
    "python": "class Solution:\n    def maximalNetworkRank(self, n: int, roads: List[List[int]]) -> int:\n        degree = [0] * n\n        connected = set()\n        for a, b in roads:\n            degree[a] += 1\n            degree[b] += 1\n            connected.add((min(a, b), max(a, b)))\n        best = 0\n        for i in range(n):\n            for j in range(i + 1, n):\n                rank = degree[i] + degree[j] - (1 if (i, j) in connected else 0)\n                if rank > best:\n                    best = rank\n        return best\n",
    "javascript": "var maximalNetworkRank = function(n, roads) {\n    const degree = new Array(n).fill(0);\n    const connected = new Set();\n    for (const [a, b] of roads) {\n        degree[a]++;\n        degree[b]++;\n        const key = a < b ? a * 1000 + b : b * 1000 + a;\n        connected.add(key);\n    }\n    let best = 0;\n    for (let i = 0; i < n; i++) {\n        for (let j = i + 1; j < n; j++) {\n            const key = i * 1000 + j;\n            const rank = degree[i] + degree[j] - (connected.has(key) ? 1 : 0);\n            if (rank > best) best = rank;\n        }\n    }\n    return best;\n};\n"
  },
  "complexity": {
    "time": "O(n^2 + m)",
    "space": "O(n^2)"
  }
