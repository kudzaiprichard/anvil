  "oracle_python": "class Solution:\n    def countValidSubsets(self, parent, nums, k):\n        MOD = 10 ** 9 + 7\n        n = len(parent)\n        children = [[] for _ in range(n)]\n        for i in range(1, n):\n            children[parent[i]].append(i)\n\n        from functools import lru_cache\n\n        def merge(a, b):\n            res = [0] * k\n            for r1 in range(k):\n                if a[r1] == 0:\n                    continue\n                for r2 in range(k):\n                    if b[r2]:\n                        res[(r1 + r2) % k] = (res[(r1 + r2) % k] + a[r1] * b[r2]) % MOD\n            return res\n\n        def dfs(v):\n            not_incl = [0] * k\n            not_incl[0] = 1\n            incl_base = [0] * k\n            incl_base[0] = 1\n            for c in children[v]:\n                c_not, c_incl = dfs(c)\n                c_total = [(c_not[r] + c_incl[r]) % MOD for r in range(k)]\n                not_incl = merge(not_incl, c_total)\n                incl_base = merge(incl_base, c_not)\n            shift = nums[v] % k\n            incl = [0] * k\n            for r in range(k):\n                if incl_base[r]:\n                    incl[(r + shift) % k] = (incl[(r + shift) % k] + incl_base[r]) % MOD\n            return not_incl, incl\n\n        root_not, root_incl = dfs(0)\n        total0 = (root_not[0] + root_incl[0]) % MOD\n        return (total0 - 1) % MOD\n",
  "solutions": {
    "python": "class Solution:\n    def countValidSubsets(self, parent, nums, k):\n        MOD = 10 ** 9 + 7\n        n = len(parent)\n        children = [[] for _ in range(n)]\n        for i in range(1, n):\n            children[parent[i]].append(i)\n\n        notIncl = [None] * n\n        incl = [None] * n\n\n        for v in range(n - 1, -1, -1):\n            base_not = [0] * k\n            base_incl_children = [0] * k\n            base_not[0] = 1\n            base_incl_children[0] = 1\n            for c in children[v]:\n                Dc = [(notIncl[c][r] + incl[c][r]) % MOD for r in range(k)]\n                new_not = [0] * k\n                for r1 in range(k):\n                    if base_not[r1] == 0:\n                        continue\n                    b = base_not[r1]\n                    for r2 in range(k):\n                        if Dc[r2]:\n                            new_not[(r1 + r2) % k] = (new_not[(r1 + r2) % k] + b * Dc[r2]) % MOD\n                base_not = new_not\n\n                new_incl_base = [0] * k\n                for r1 in range(k):\n                    if base_incl_children[r1] == 0:\n                        continue\n                    b = base_incl_children[r1]\n                    for r2 in range(k):\n                        if notIncl[c][r2]:\n                            new_incl_base[(r1 + r2) % k] = (new_incl_base[(r1 + r2) % k] + b * notIncl[c][r2]) % MOD\n                base_incl_children = new_incl_base\n\n            notIncl[v] = base_not\n            shift = nums[v] % k\n            incl_v = [0] * k\n            for r in range(k):\n                if base_incl_children[r]:\n                    incl_v[(r + shift) % k] = (incl_v[(r + shift) % k] + base_incl_children[r]) % MOD\n            incl[v] = incl_v\n\n        total0 = (notIncl[0][0] + incl[0][0]) % MOD\n        return (total0 - 1) % MOD\n",
    "javascript": "var countValidSubsets = function(parent, nums, k) {\n    const MOD = 1000000007n;\n    const n = parent.length;\n    const children = Array.from({length: n}, () => []);\n    for (let i = 1; i < n; i++) children[parent[i]].push(i);\n\n    const notIncl = new Array(n);\n    const incl = new Array(n);\n\n    for (let v = n - 1; v >= 0; v--) {\n        let baseNot = new Array(k).fill(0n);\n        let baseInclChildren = new Array(k).fill(0n);\n        baseNot[0] = 1n;\n        baseInclChildren[0] = 1n;\n        for (const c of children[v]) {\n            const Dc = new Array(k);\n            for (let r = 0; r < k; r++) Dc[r] = (notIncl[c][r] + incl[c][r]) % MOD;\n\n            const newNot = new Array(k).fill(0n);\n            for (let r1 = 0; r1 < k; r1++) {\n                const b = baseNot[r1];\n                if (b === 0n) continue;\n                for (let r2 = 0; r2 < k; r2++) {\n                    if (Dc[r2] !== 0n) {\n                        const idx = (r1 + r2) % k;\n                        newNot[idx] = (newNot[idx] + b * Dc[r2]) % MOD;\n                    }\n                }\n            }\n            baseNot = newNot;\n\n            const newInclBase = new Array(k).fill(0n);\n            for (let r1 = 0; r1 < k; r1++) {\n                const b = baseInclChildren[r1];\n                if (b === 0n) continue;\n                for (let r2 = 0; r2 < k; r2++) {\n                    if (notIncl[c][r2] !== 0n) {\n                        const idx = (r1 + r2) % k;\n                        newInclBase[idx] = (newInclBase[idx] + b * notIncl[c][r2]) % MOD;\n                    }\n                }\n            }\n            baseInclChildren = newInclBase;\n        }\n\n        notIncl[v] = baseNot;\n        const shift = ((nums[v] % k) + k) % k;\n        const inclV = new Array(k).fill(0n);\n        for (let r = 0; r < k; r++) {\n            if (baseInclChildren[r] !== 0n) {\n                const idx = (r + shift) % k;\n                inclV[idx] = (inclV[idx] + baseInclChildren[r]) % MOD;\n            }\n        }\n        incl[v] = inclV;\n    }\n\n    const total0 = (notIncl[0][0] + incl[0][0]) % MOD;\n    let ans = (total0 - 1n) % MOD;\n    if (ans < 0n) ans += MOD;\n    return Number(ans);\n};\n"
