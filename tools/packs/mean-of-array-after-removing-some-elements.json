  "oracle_python": "class Solution:\n    def trimMean(self, arr: List[int]) -> float:\n        n = len(arr)\n        k = n // 20\n        ordered = sorted(arr)\n        total = sum(ordered)\n        total -= sum(ordered[:k])\n        total -= sum(ordered[n - k:])\n        return total / (n - 2 * k)\n",
  "solutions": {
    "python": "class Solution:\n    def trimMean(self, arr: List[int]) -> float:\n        n = len(arr)\n        k = n // 20\n        ordered = sorted(arr)\n        middle = ordered[k:n - k]\n        return sum(middle) / len(middle)\n",
    "javascript": "var trimMean = function(arr) {\n    const n = arr.length;\n    const k = Math.floor(n / 20);\n    const ordered = [...arr].sort((a, b) => a - b);\n    const middle = ordered.slice(k, n - k);\n    const sum = middle.reduce((s, v) => s + v, 0);\n    return sum / middle.length;\n};\n"
  },
  "complexity": {
    "time": "O(n log n)",
    "space": "O(n)"
  }
}
