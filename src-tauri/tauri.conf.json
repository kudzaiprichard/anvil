{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Anvil",
  "version": "0.5.0",
  "identifier": "com.anvil.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run catalog:fetch:dev && npm run dev",
    "beforeBuildCommand": "npm run catalog:fetch:prod && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Anvil",
        "width": 1280,
        "height": 832,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Anvil",
    "homepage": "https://github.com/kudzaiprichard/anvil",
    "copyright": "Copyright © 2026 Anvil contributors. MIT License.",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "category": "Education",
    "shortDescription": "The free, offline, honest way to master DSA.",
    "longDescription": "Anvil is a free, offline desktop app for coding-interview and data-structures practice. Work through a guided course of original problems — learn each pattern with an animated diagram, check yourself with a quick quiz, then write your solution in the built-in editor and run it against real test cases in a sandboxed local runtime. No account, no network, no AI crutch.",
    "resources": [
      "resources/catalog",
      "resources/presets/*.json",
      "resources/test-packs.json.gz",
      "resources/pylib/**/*",
      "resources/curriculum/**/*.json",
      "resources/lessons"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/nsis-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp"
      },
      "wix": {
        "bannerPath": "installer/wix-banner.bmp",
        "dialogImagePath": "installer/wix-dialog.bmp"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "background": "installer/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 168,
          "y": 236
        },
        "applicationFolderPosition": {
          "x": 492,
          "y": 236
        }
      }
    },
    "linux": {
      "deb": {
        "section": "education"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
