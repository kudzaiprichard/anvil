{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Anvil",
  "version": "0.2.0",
  "identifier": "com.anvil.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Anvil",
        "width": 1280,
        "height": 832,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/catalog",
      "resources/presets/*.json",
      "resources/test-packs.json.gz",
      "resources/pylib/**/*",
      "resources/curriculum/**/*.json",
      "resources/lessons"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
